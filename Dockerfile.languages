# nanocodex-languages — the base nanocodex runtime image plus the mcp-js
# "toolbox" WASM language engines (picat, tla+, minizinc, autolisp, lua,
# craftos) and their bootstrap.js at /opt/languages/. The base image is NOT
# modified; this is a separate image, and which one an instance runs is a
# deploy-time choice (docker-compose.yml: --profile languages). A bridge
# pointed at a languages instance runs with NANOCODEX_SANDBOX=languages so
# threads get the engines via per-thread --wasm-module flags — see
# client/nanocodex_client/agui/sandbox.py.
#
# BASE_IMAGE defaults to the published base; docker-compose overrides it with
# the locally built one (additional_contexts: service:codex).

ARG BASE_IMAGE=ghcr.io/r33drichards/nanocodex:latest

# ── Stage 1: vendor + generate bootstrap.js (the bundled languages) ─────────
FROM node:22-bookworm-slim AS gen
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /build
COPY languages/fetch-vendor.sh languages/build-bootstrap.mjs ./
COPY languages/src ./src
COPY languages/engines ./engines
RUN ./fetch-vendor.sh
RUN node build-bootstrap.mjs /build/bootstrap.js

# ── Stage 2: layer the language assets onto the base runtime ────────────────
FROM ${BASE_IMAGE}

# For bases that run the AG-UI bridge in-container (the standalone images),
# bake the sandbox preset so threads get the engines without extra env
# plumbing. Inert on the plain base image (nothing there reads it).
ARG SANDBOX_PRESET=default
ENV NANOCODEX_SANDBOX=${SANDBOX_PRESET}

COPY --from=gen /build/bootstrap.js /opt/languages/bootstrap.js
COPY --from=gen /build/vendor/picat.wasm /build/vendor/tla_checker.wasm \
                /build/vendor/minizinc.wasm /build/vendor/acadlisp.wasm \
                /build/vendor/lua.wasm /build/vendor/craftos.wasm /opt/languages/
# Sandbox policy for languages threads: allow-all fetch (reuses the base
# image's /app/policies/fetch.rego) + fs narrowed to read-only /opt/languages
# and read-write /work.
COPY languages/filesystem.rego languages/policies.json /opt/languages/
