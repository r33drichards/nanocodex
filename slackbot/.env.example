# --- Slack (create the app from slack-app-manifest.yaml) ---
# Bot token (OAuth & Permissions → Install App): xoxb-...
SLACK_BOT_TOKEN=
# App-level token with connections:write (Basic Information → App-Level Tokens): xapp-...
SLACK_APP_TOKEN=

# --- Agent backend: the nanocodex AG-UI bridge ---
# POST /agui endpoint (see client/nanocodex_client/agui/README.md)
AGENT_URL=http://127.0.0.1:8130/agui
# Optional Authorization header value forwarded on every run, e.g. "Bearer ..."
#AGENT_AUTH_HEADER=

# Set to 1 to hide the ":wrench: run_js" tool-status rows in Slack replies
#SLACK_HIDE_TOOL_STATUS=1
